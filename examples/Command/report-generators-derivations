{
    "report.generators": {
         "my-report": {
             "generator": "expression",
             "cols": [ "benchmark", "subject", "mode", "super mode" ],
             "derivations": {
                 "super mode": "row['mode'] ~ ' of ' ~ sum(table['mode'])"
             }
         }
    }
}
---
phpbench run --report=my-report --executor=debug MultipleSubjects.php --progress=none
---
